# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Directories (absolute paths inside container)
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs
MODELS_CACHE_DIR=/app/models_cache

# Docker Hub (used by CI/CD and docker-compose in prod)
DOCKERHUB_USERNAME=your-dockerhub-username

# Server (fill in after provisioning Hetzner)
HETZNER_IP=1.2.3.4
DEPLOY_USER=deploy

# CORS — comma-separated allowed origins for FastAPI
# Set to your Vercel domain in production
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
